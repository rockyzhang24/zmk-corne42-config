#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

/ {
    behaviors {
        hml: homewrow_mods_left {
            compatible = "zmk,behavior-hold-tap";
            label = "HOMEROW_MODS_LEFT_HAND";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "balanced";
            hold-trigger-on-release;
        };

        hmr: homewrow_mods_right {
            compatible = "zmk,behavior-hold-tap";
            label = "HOMEROW_MODS_RIGHT_HAND";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "balanced";
            hold-trigger-on-release;
        };

        hyper_or_f19: hyper_or_f19 {
            compatible = "zmk,behavior-hold-tap";
            label = "HYPER_OR_F19";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "hold-preferred";
        };

        meh_or_f20: meh_or_f20 {
            compatible = "zmk,behavior-hold-tap";
            label = "MEH_OR_F20";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "hold-preferred";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default {
            bindings = <
&kp TAB  &kp Q        &kp W        &kp E                         &kp R         &kp T        &kp Y      &kp U          &kp I                               &kp O        &kp P                &kp BSPC
&kp ESC  &hml LCMD A  &hml LALT S  &hml LCTRL D                  &hml LSHFT F  &kp G        &kp H      &hmr LSHIFT J  &hmr LCTRL K                        &hmr LALT L  &hmr LCMD SEMICOLON  &kp APOS
&trans   &kp Z        &kp X        &kp C                         &kp V         &kp B        &kp N      &kp M          &kp COMMA                           &kp DOT      &kp FSLH             &kp NON_US_BACKSLASH
                                   &meh_or_f20 LC(LS(LALT)) F20  &mo 1         &kp SPACE    &kp ENTER  &mo 2          &hyper_or_f19 LA(LC(LS(LCMD))) F19
            >;
        };

        lower_layer {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  1  |  2  |  3  |  4  |  5  |   |  6  |  7  |  8  |  9  |  0  | BSPC |
            // | BTCLR| BT1 | BT2 | BT3 | BT4 | BT5 |   | LFT | DWN |  UP | RGT |     |      |
            // | SHFT |     |     |     |     |     |   |     |     |     |     |     |      |
            //                    | GUI |     | SPC |   | ENT |     | ALT |

            bindings = <
&trans  &kp GRAVE             &kp PIPE             &kp LEFT_BRACKET             &kp RIGHT_BRACKET              &none          &kp CARET        &kp NUMBER_7          &kp NUMBER_8         &kp NUMBER_9        &kp PLUS         &kp BSPC
&trans  &hml LCMD UNDERSCORE  &hml LALT AMPERSAND  &hml LCTRL LEFT_PARENTHESIS  &hml LSHIFT RIGHT_PARENTHESIS  &kp HASH       &kp EXCLAMATION  &hmr LSHIFT NUMBER_4  &hmr LCTRL NUMBER_5  &hmr LALT NUMBER_6  &hmr LCMD MINUS  &kp PERCENT
&trans  &trans                &kp DOLLAR           &kp LEFT_BRACE               &kp RIGHT_BRACE                &kp AT_SIGN    &kp TILDE        &kp NUMBER_1          &kp NUMBER_2         &kp NUMBER_3        &kp ASTERISK     &trans
                                                   &trans                       &trans                         &kp SPACE      &kp RET          &kp NUMBER_0          &kp EQUAL
            >;
        };

        raise_layer {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  !  |  @  |  #  |  $  |  %  |   |  ^  |  &  |  *  |  (  |  )  | BSPC |
            // | CTRL |     |     |     |     |     |   |  -  |  =  |  [  |  ]  |  \  |  `   |
            // | SHFT |     |     |     |     |     |   |  _  |  +  |  {  |  }  | "|" |  ~   |
            //                    | GUI |     | SPC |   | ENT |     | ALT |

            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans       &kp HOME        &kp PAGE_DOWN           &kp PAGE_UP          &kp END                &bt BT_PRV                  &bt BT_NXT
&trans  &trans  &trans  &trans  &trans  &trans       &kp LEFT_ARROW  &hmr LSHIFT DOWN_ARROW  &hmr LCTRL UP_ARROW  &hmr LALT RIGHT_ARROW  &hmr LCMD C_BRIGHTNESS_DEC  &kp C_BRIGHTNESS_INC
&trans  &trans  &trans  &trans  &trans  &trans       &bt BT_CLR      &kp C_MUTE              &kp C_VOLUME_DOWN    &kp C_VOLUME_UP        &trans                      &trans
                        &trans  &trans  &kp SPACE    &kp RET         &trans                  &trans
            >;
        };
    };
};
